MTD	sample_processing[3]	[, , Chromatography, ]
MTD	sample_processing[4]	[, , Mass spectrometry, ]
MTD	software[1]	[, , Leco ChromaTOF, 2.32]
MTD	software[2]	[, , MATLAB, 6.5]
MTD	software[3]	[, , mtbls2mztabm, 1.0]
